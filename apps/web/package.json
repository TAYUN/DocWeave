{
  "name": "@docweave/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "theme:dark": "node ./scripts/generate-dark-tokens.mjs",
    "theme:dark:soft": "node ./scripts/generate-dark-tokens.mjs --preset soft",
    "theme:dark:contrast": "node ./scripts/generate-dark-tokens.mjs --preset contrast"
  },
  "dependencies": {
    "@docweave/adapters": "workspace:*",
    "@docweave/api": "workspace:*",
    "@docweave/contracts": "workspace:*",
    "@docweave/editor": "workspace:*",
    "@hocuspocus/provider": "^4.3.0",
    "@mantine/core": "9.4.1",
    "@mantine/hooks": "9.4.1",
    "@mantine/notifications": "9.4.1",
    "@mantine/utils": "6.0.22",
    "@tailwindcss/vite": "4.3.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.17",
    "@tuyau/core": "^1.2.2",
    "lucide-react": "1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "4.3.2",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
