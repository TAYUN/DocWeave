# Node
TZ=UTC
PORT=3333
HOST=127.0.0.1
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}
COLLAB_SECRET=

# Session
SESSION_DRIVER=cookie

# Database
DB_CONNECTION=pg
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_DATABASE=docweave

# M4 stable snapshot / index baseline
# API 当前只直接依赖数据库与业务密钥；下面这些变量同时给 worker 复用，方便本地联调保持一套口径。
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=document_chunks_v1

DASHSCOPE_API_KEY=
# 北京地域示例。若使用新加坡地域，请替换为对应 workspace 的 ap-southeast-1 地址。
DASHSCOPE_BASE_URL=https://{WorkspaceId}.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
EMBEDDING_PROVIDER=aliyun_openai_compatible
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024

WORKER_POLL_INTERVAL_MS=3000
WORKER_JOB_LEASE_MS=30000

#--------------------------------------------------------------------
# CORS (configure allowed origins for API access)
#--------------------------------------------------------------------
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000
