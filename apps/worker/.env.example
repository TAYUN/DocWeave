# Node
TZ=UTC
NODE_ENV=development
HOST=127.0.0.1
PORT=3335

# Database
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_DATABASE=docweave

# Qdrant
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=document_chunks_v1

# Embedding provider
DASHSCOPE_API_KEY=
# 北京地域示例。若使用新加坡地域，请替换为对应 workspace 的 ap-southeast-1 地址。
DASHSCOPE_BASE_URL=https://{WorkspaceId}.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
EMBEDDING_PROVIDER=aliyun_openai_compatible
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024

# Worker loop
WORKER_POLL_INTERVAL_MS=3000
WORKER_JOB_LEASE_MS=30000
